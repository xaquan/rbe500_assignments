<?xml version="1.0"?>
<robot name="3dof_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="d1" value=".6" />
    <xacro:property name="a2" value=".6" />
    <xacro:property name="a3" value=".6" />
    <xacro:property name="d4" value=".3" />

    
    <xacro:property name="cyl_joint_r" value=".1" />
    <xacro:property name="cyl_joint_l" value=".2" />

    <xacro:property name="link_r" value=".1" />

    <xacro:property name="base_link_l" value=".5" />
    <xacro:property name="base_link_w" value=".5" />
    <xacro:property name="base_link_h" value="0.1" />

    <xacro:property name="link1_l" value="${d1}" />
    <xacro:property name="link1_r" value="${link_r}" />
    <xacro:property name="link1_theta" value="0" />
    <xacro:property name="link1_d" value="${base_link_h}" />
    <xacro:property name="link1_a" value="0" />
    <xacro:property name="link1_alpha" value="0" />

    <xacro:property name="link2_l" value="${a2}" />
    <xacro:property name="link2_w" value="${link_r *2}" />   
    <xacro:property name="link2_h" value="${link_r}" />
    <xacro:property name="link2_theta" value="0" />
    <xacro:property name="link2_d" value="${link1_l}" />
    <xacro:property name="link2_a" value="0" />
    <xacro:property name="link2_alpha" value="0" />

    <xacro:property name="link3_l" value="${cyl_joint_l}" />
    <xacro:property name="link3_r" value="${cyl_joint_r}" />
    <xacro:property name="link3_theta" value="0" />
    <xacro:property name="link3_d" value="0" />
    <xacro:property name="link3_a" value="${a2}" />
    <xacro:property name="link3_alpha" value="0" />

    <xacro:property name="ee_w" value="0.4" />
    <xacro:property name="ee_h" value="0.05" />
    <xacro:property name="ee_limit_lower" value="0" />
    <xacro:property name="ee_limit_upper" value=".5" />

    <xacro:macro name="inertial_box" params="mass x y z *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}" />
            <inertia ixx="${(1/12) * mass * (y*y+z*z)}" ixy="0.0" ixz="0.0"
                    iyy="${(1/12) * mass * (x*x+z*z)}" iyz="0.0"
                    izz="${(1/12) * mass * (x*x+y*y)}" />
        </inertial>
    </xacro:macro>

    <xacro:macro name="inertial_cylinder" params="mass length radius *origin">
        <inertial>
            <xacro:insert_block name="origin"/>
            <mass value="${mass}" />
            <inertia ixx="${(1/12) * mass * (3*radius*radius + length*length)}" ixy="0.0" ixz="0.0"
                    iyy="${(1/12) * mass * (3*radius*radius + length*length)}" iyz="0.0"
                    izz="${(1/2) * mass * (radius*radius)}" />
        </inertial>
    </xacro:macro>

    <link name="world_link"/>

    <joint name="world_to_base" type="fixed">
    <parent link="world_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 ${base_link_h/2}" />
        <geometry>
            <box size="${base_link_l} ${base_link_w} ${base_link_h}" />
        </geometry>
    </visual>
    <collision>
        <origin rpy="0 0 0" xyz="0 0 ${base_link_h/2}" />
        <geometry>
            <box size="${base_link_l} ${base_link_w} ${base_link_h}" />
        </geometry>
    </collision>
    <xacro:inertial_box mass="10" x="${base_link_l}" y="${base_link_w}" z="${base_link_h}">
        <origin rpy="0 0 0" xyz="0 0 ${base_link_h/2}" />
    </xacro:inertial_box>
    </link>    

    <joint name="joint1" type="continuous">
        <parent link="base_link" />
        <child link="link1" />
        <origin rpy="0 0 0" xyz="0 0 ${link1_d}" />
        <axis xyz="0 0 1" />
    </joint>

    <link name="link1">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 ${link1_l/2}" />
            <geometry>
                <cylinder length="${link1_l}" radius="${link1_r}" />
            </geometry>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 ${link1_l/2}" />
            <geometry>
                <cylinder length="${link1_l}" radius="${link1_r}" />
            </geometry>
        </collision>        
        <xacro:inertial_cylinder mass="10" length="${link1_l}" radius="${link1_r}">
            <origin rpy="0 0 0" xyz="0 0 ${link1_l/2}" />
        </xacro:inertial_cylinder>
    </link>

    <link name="link2">
        <visual>
            <origin rpy="0 0 0" xyz="${link2_l/2} 0 0" />
            <geometry>
                <box size="${link2_l} ${link2_w} ${link2_h}" />
            </geometry>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="${link2_l/2} 0 0" />
            <geometry>                
                <box size="${link2_l} ${link2_w} ${link2_h}" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.01" x="${link2_l}" y="${link2_w}" z="${link2_h}">
            <origin rpy="0 0 0" xyz="${link2_l/2} 0 0" />
        </xacro:inertial_box>
    </link>

    <joint name="link1_to_link2" type="fixed">
        <parent link="link1" />
        <child link="link2" />
        <origin rpy="${link2_theta} 0 ${link2_alpha}" xyz="${link2_a} 0 ${link2_d}" />
    </joint>


    <link name="link3">
        <visual>
            <geometry>
                <cylinder length="${link3_l}" radius="${link3_r}" />
            </geometry>
        </visual>
        <collision>
            <geometry>
                <cylinder length="${link3_l}" radius="${link3_r}" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.01" />
            <inertia ixx="1e-3" ixy="0.0" ixz="0.0" iyy="1e-3" iyz="0.0" izz="1e-3" />
        </inertial>
    </link>

    <joint name="joint2" type="revolute">
        <parent link="link2" />
        <child link="link3" />
        <origin rpy="${link3_theta} 0 ${link3_alpha}" xyz="${link3_a} 0 ${link3_d}" />
        <limit lower="${-pi/2}" upper="${pi/2}" effort="100" velocity="1.0" />
        <axis xyz="0 0 1" />
    </joint>

    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>
        <joint name="joint1">
            <command_interface name="position" />
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="joint2">
            <command_interface name="position" />
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
        <parameters>$(find assign1)/config/joints.yaml</parameters>
        </plugin>
    </gazebo>
</robot>